# CRAFT
# ======================================================================================================================
# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# The environment Craft is currently running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# The secure key Craft will use for hashing and encrypting data
CRAFT_SECURITY_KEY=

# Database connection settings
CRAFT_DB_DRIVER=mysql
CRAFT_DB_SERVER=ddev-local-db-path
CRAFT_DB_PORT=3306
CRAFT_DB_DATABASE=db
CRAFT_DB_USER=db
CRAFT_DB_PASSWORD=db
CRAFT_DB_SCHEMA=
CRAFT_DB_TABLE_PREFIX=

# VITE
# ======================================================================================================================
# This is dynamically updated using the viteDevServerToggle.js script.
USE_VITE_DEV_SERVER=1

# GENERAL
# ======================================================================================================================
# General settings (see config/general.php)
DEV_MODE=true
ALLOW_ADMIN_CHANGES=true
DISALLOW_ROBOTS=true
PRIMARY_SITE_URL=ddev-local-site-url.local
CP_TRIGGER=cms
# SYSTEM_EMAIL=

# Servd
SERVD_PROJECT_SLUG=
SERVD_SECURITY_KEY=
SERVD_BASE_URL=
SERVD_UPLOADS=uploads/
SERVD_ICONS=icons/
SERVD_SEQUENCE=

S3_PUBLIC_URL=
S3_KEY=
S3_SECRET=
CF_DISTRIBUTION_ID=


# SMTP

# mailhog
